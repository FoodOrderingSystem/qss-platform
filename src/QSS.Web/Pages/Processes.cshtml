@page
@model QSS.Web.Pages.ProcessesModel
@{ ViewData["Title"] = "Processes"; }

<div x-data="processesApp()" x-init="load()">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Processes</h1>
            <p class="text-sm text-gray-500 mt-0.5">Manage quality processes and workflow categories</p>
        </div>
        <button @@click="openCreate()" class="btn-primary"><i class="fas fa-plus"></i> New Process</button>
    </div>

    <!-- Loading skeleton -->
    <div x-show="loading" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <template x-for="i in [1,2,3,4,5,6]" :key="i">
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 animate-pulse">
                <div class="flex items-start justify-between mb-3">
                    <div class="w-10 h-10 bg-gray-100 rounded-lg"></div>
                    <div class="h-5 w-20 bg-gray-100 rounded-full"></div>
                </div>
                <div class="h-4 bg-gray-100 rounded mb-2 w-3/4"></div>
                <div class="h-3 bg-gray-100 rounded w-full mb-3"></div>
                <div class="h-3 bg-gray-100 rounded w-1/3"></div>
            </div>
        </template>
    </div>

    <!-- Empty state -->
    <div x-show="!loading && processes.length === 0" class="flex flex-col items-center justify-center py-24 text-center">
        <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center mb-4">
            <i class="fas fa-project-diagram text-2xl text-blue-300"></i>
        </div>
        <p class="text-gray-500 font-medium mb-1">No processes yet</p>
        <p class="text-xs text-gray-300 mb-4">Create your first quality process to get started</p>
        <button @@click="openCreate()" class="btn-primary text-sm"><i class="fas fa-plus"></i> New Process</button>
    </div>

    <!-- Process cards -->
    <div x-show="!loading && processes.length > 0" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <template x-for="p in processes" :key="p.id">
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-all cursor-pointer group"
                 @@click="openDetail(p.id)">
                <div class="flex items-start justify-between mb-3">
                    <div class="w-10 h-10 rounded-lg flex items-center justify-center" :class="categoryColor(p.category)">
                        <i class="fas fa-project-diagram text-white text-sm"></i>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full" x-text="p.category"></span>
                        <span x-show="!p.isActive" class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Inactive</span>
                    </div>
                </div>
                <h3 class="font-semibold text-gray-900 mb-1 group-hover:text-blue-600 transition-colors" x-text="p.name"></h3>
                <p class="text-xs text-gray-500 mb-4 line-clamp-2" x-text="p.description || 'No description'"></p>
                <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-400 flex items-center gap-1">
                        <i class="fas fa-tasks"></i>
                        <span x-text="p.taskCount + ' task' + (p.taskCount !== 1 ? 's' : '')"></span>
                    </span>
                    <div class="flex items-center gap-2">
                        <button @@click.stop="openEdit(p)" class="text-gray-400 hover:text-blue-600 p-1 opacity-0 group-hover:opacity-100 transition-opacity" title="Edit">
                            <i class="fas fa-pencil text-xs"></i>
                        </button>
                        <button @@click.stop="deleteProcess(p.id)" class="text-red-400 hover:text-red-600 p-1 opacity-0 group-hover:opacity-100 transition-opacity" title="Delete">
                            <i class="fas fa-trash text-xs"></i>
                        </button>
                        <span class="text-xs text-blue-400 opacity-0 group-hover:opacity-100 transition-opacity">View →</span>
                    </div>
                </div>
            </div>
        </template>
    </div>

    <!-- Process Detail Slide-over -->
    <div x-show="showDetail" class="fixed inset-0 z-50 overflow-hidden" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
        <div class="absolute inset-0 bg-gray-900/40" @@click="showDetail = false"></div>
        <div class="absolute right-0 top-0 h-full w-full max-w-lg bg-white shadow-2xl flex flex-col"
             x-transition:enter="transition ease-out duration-200" x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0"
             x-transition:leave="transition ease-in duration-150" x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full">

            <!-- Header -->
            <div x-show="detailLoading" class="flex-1 flex items-center justify-center">
                <div class="text-center text-gray-400">
                    <i class="fas fa-spinner fa-spin text-2xl mb-2"></i>
                    <p class="text-sm">Loading...</p>
                </div>
            </div>

            <template x-if="!detailLoading && selectedProcess">
                <div class="flex flex-col h-full">
                    <div class="flex items-start justify-between p-6 border-b border-gray-100">
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 rounded-xl flex items-center justify-center" :class="categoryColor(selectedProcess.category)">
                                <i class="fas fa-project-diagram text-white"></i>
                            </div>
                            <div>
                                <h2 class="text-lg font-bold text-gray-900" x-text="selectedProcess.name"></h2>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full" x-text="selectedProcess.category"></span>
                                    <span x-show="!selectedProcess.isActive" class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Inactive</span>
                                </div>
                            </div>
                        </div>
                        <button @@click="showDetail = false" class="text-gray-400 hover:text-gray-600 p-1 mt-1">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>

                    <div class="flex-1 overflow-y-auto p-6 space-y-6">
                        <!-- Description -->
                        <div x-show="selectedProcess.description">
                            <p class="text-sm text-gray-600 leading-relaxed" x-text="selectedProcess.description"></p>
                        </div>

                        <!-- Stats row -->
                        <div class="grid grid-cols-3 gap-3">
                            <div class="bg-blue-50 rounded-xl p-3 text-center">
                                <p class="text-xl font-bold text-blue-600" x-text="selectedProcess.taskCount ?? 0"></p>
                                <p class="text-xs text-blue-500 mt-0.5">Total Tasks</p>
                            </div>
                            <div class="bg-green-50 rounded-xl p-3 text-center">
                                <p class="text-xl font-bold text-green-600" x-text="selectedProcess.completedTaskCount ?? 0"></p>
                                <p class="text-xs text-green-500 mt-0.5">Completed</p>
                            </div>
                            <div class="rounded-xl p-3 text-center" :class="(selectedProcess.overdueTaskCount ?? 0) > 0 ? 'bg-red-50' : 'bg-gray-50'">
                                <p class="text-xl font-bold" :class="(selectedProcess.overdueTaskCount ?? 0) > 0 ? 'text-red-600' : 'text-gray-500'" x-text="selectedProcess.overdueTaskCount ?? 0"></p>
                                <p class="text-xs mt-0.5" :class="(selectedProcess.overdueTaskCount ?? 0) > 0 ? 'text-red-400' : 'text-gray-400'">Overdue</p>
                            </div>
                        </div>

                        <!-- Task list -->
                        <div>
                            <h3 class="text-sm font-semibold text-gray-700 mb-3 flex items-center justify-between">
                                <span>Tasks in this process</span>
                                <span class="text-xs font-normal text-gray-400" x-text="(selectedProcess.tasks?.length ?? 0) + ' total'"></span>
                            </h3>
                            <div x-show="!selectedProcess.tasks || selectedProcess.tasks.length === 0" class="text-center py-8 text-gray-400">
                                <i class="fas fa-clipboard-list text-2xl mb-2"></i>
                                <p class="text-xs">No tasks yet</p>
                            </div>
                            <div class="space-y-2 max-h-72 overflow-y-auto">
                                <template x-for="t in selectedProcess.tasks" :key="t.id">
                                    <div class="flex items-center gap-3 bg-gray-50 rounded-lg px-3 py-2.5 hover:bg-gray-100 transition-colors">
                                        <div class="w-2 h-2 rounded-full flex-shrink-0" :class="taskStatusDot(t.status)"></div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-medium text-gray-800 truncate" x-text="t.name"></p>
                                            <p class="text-xs text-gray-400" x-text="t.assigneeName ? 'Assigned to ' + t.assigneeName : 'Unassigned'"></p>
                                        </div>
                                        <div class="flex-shrink-0 flex items-center gap-2">
                                            <span x-show="t.isOverdue" class="text-xs bg-red-100 text-red-600 px-1.5 py-0.5 rounded font-medium">OVERDUE</span>
                                            <span class="text-xs px-2 py-0.5 rounded-full font-medium" :class="taskStatusBadge(t.status)" x-text="t.status"></span>
                                        </div>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>

                    <!-- Footer actions -->
                    <div class="p-4 border-t border-gray-100 flex justify-between items-center bg-gray-50">
                        <button @@click="showDetail = false; deleteProcess(selectedProcess.id)"
                                class="text-sm text-red-500 hover:text-red-700 flex items-center gap-1.5 px-3 py-2 rounded-lg hover:bg-red-50 transition-colors">
                            <i class="fas fa-trash text-xs"></i> Delete Process
                        </button>
                        <div class="flex gap-2">
                            <button @@click="showDetail = false" class="btn-secondary text-sm">Close</button>
                            <button @@click="showDetail = false; openEditById(selectedProcess)" class="btn-primary text-sm">
                                <i class="fas fa-pencil mr-1"></i> Edit
                            </button>
                        </div>
                    </div>
                </div>
            </template>
        </div>
    </div>

    <!-- Create Modal -->
    <div x-show="showCreate" class="modal-backdrop" x-transition>
        <div class="modal p-6" style="max-width:480px">
            <div class="flex items-center justify-between mb-5">
                <div>
                    <h2 class="text-lg font-bold text-gray-900">Create Process</h2>
                    <p class="text-xs text-gray-400 mt-0.5">Define a new quality management process</p>
                </div>
                <button @@click="showCreate = false" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
            </div>
            <form x-on:submit.prevent="createProcess()">
                <div class="space-y-4">
                    <div>
                        <label class="form-label">Name <span class="text-red-500">*</span></label>
                        <input x-model="form.name" type="text" class="form-input" required placeholder="e.g. Daily Sterilization Check" />
                    </div>
                    <div>
                        <label class="form-label">Category</label>
                        <select x-model="form.category" class="form-input">
                            <option value="0">Hygiene</option>
                            <option value="1">Maintenance</option>
                            <option value="2">Administrative</option>
                            <option value="3">Clinical</option>
                            <option value="4">Safety</option>
                            <option value="5">Training</option>
                            <option value="6">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Description</label>
                        <textarea x-model="form.description" class="form-input" rows="3" placeholder="Describe what this process covers and when it applies..."></textarea>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" @@click="showCreate = false" class="btn-secondary">Cancel</button>
                    <button type="submit" class="btn-primary" :disabled="saving" x-text="saving ? 'Creating...' : 'Create Process'"></button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Modal -->
    <div x-show="showEdit" class="modal-backdrop" x-transition>
        <div class="modal p-6" style="max-width:480px">
            <div class="flex items-center justify-between mb-5">
                <div>
                    <h2 class="text-lg font-bold text-gray-900">Edit Process</h2>
                    <p class="text-xs text-gray-400 mt-0.5">Update process details</p>
                </div>
                <button @@click="showEdit = false" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
            </div>
            <form x-on:submit.prevent="updateProcess()">
                <div class="space-y-4">
                    <div>
                        <label class="form-label">Name <span class="text-red-500">*</span></label>
                        <input x-model="editForm.name" type="text" class="form-input" required />
                    </div>
                    <div>
                        <label class="form-label">Category</label>
                        <select x-model="editForm.category" class="form-input">
                            <option value="0">Hygiene</option>
                            <option value="1">Maintenance</option>
                            <option value="2">Administrative</option>
                            <option value="3">Clinical</option>
                            <option value="4">Safety</option>
                            <option value="5">Training</option>
                            <option value="6">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Description</label>
                        <textarea x-model="editForm.description" class="form-input" rows="3"></textarea>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" @@click="showEdit = false" class="btn-secondary">Cancel</button>
                    <button type="submit" class="btn-primary" :disabled="saving" x-text="saving ? 'Saving...' : 'Save Changes'"></button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function processesApp() {
    const categoryMap = { 0: 'Hygiene', 1: 'Maintenance', 2: 'Administrative', 3: 'Clinical', 4: 'Safety', 5: 'Training', 6: 'Other' };

    return {
        processes: [],
        showCreate: false, showEdit: false, showDetail: false,
        selectedProcess: null, detailLoading: false,
        loading: true, saving: false,
        form: { name: '', description: '', category: '0' },
        editForm: { id: null, name: '', description: '', category: '0' },

        async load() {
            this.loading = true;
            try { this.processes = await apiRequest('GET', '/processes'); }
            catch(e) { showToast('Failed to load processes', 'error'); }
            finally { this.loading = false; }
        },

        openCreate() {
            this.form = { name: '', description: '', category: '0' };
            this.showCreate = true;
        },

        async openDetail(id) {
            this.showDetail = true;
            this.detailLoading = true;
            this.selectedProcess = null;
            try {
                this.selectedProcess = await apiRequest('GET', `/processes/${id}`);
            } catch(e) {
                showToast('Failed to load process details', 'error');
                this.showDetail = false;
            } finally {
                this.detailLoading = false;
            }
        },

        openEdit(p) {
            this.editForm = {
                id: p.id,
                name: p.name,
                description: p.description || '',
                category: String(Object.entries(categoryMap).find(([k,v]) => v === p.category)?.[0] ?? '0')
            };
            this.showEdit = true;
        },

        openEditById(p) {
            this.openEdit(p);
        },

        async createProcess() {
            this.saving = true;
            try {
                await apiRequest('POST', '/processes', { name: this.form.name, description: this.form.description, category: parseInt(this.form.category) });
                this.showCreate = false;
                await this.load();
                showToast('Process created successfully');
            } catch(e) { showToast('Failed to create process', 'error'); }
            finally { this.saving = false; }
        },

        async updateProcess() {
            this.saving = true;
            try {
                await apiRequest('PUT', `/processes/${this.editForm.id}`, {
                    name: this.editForm.name,
                    description: this.editForm.description,
                    category: parseInt(this.editForm.category)
                });
                this.showEdit = false;
                await this.load();
                showToast('Process updated successfully');
            } catch(e) { showToast('Failed to update process', 'error'); }
            finally { this.saving = false; }
        },

        async deleteProcess(id) {
            if(!confirm('Delete this process? This action cannot be undone if the process has no active tasks.')) return;
            try {
                await apiRequest('DELETE', `/processes/${id}`);
                this.showDetail = false;
                await this.load();
                showToast('Process deleted');
            } catch(e) {
                const msg = e.message || 'Failed to delete process';
                showToast(msg.includes('active tasks') ? 'Cannot delete: process has active tasks' : 'Failed to delete process', 'error');
            }
        },

        categoryColor(cat) {
            const map = { Hygiene: 'bg-blue-500', Maintenance: 'bg-orange-500', Administrative: 'bg-purple-500',
                Clinical: 'bg-green-500', Safety: 'bg-red-500', Training: 'bg-teal-500', Other: 'bg-gray-500' };
            return map[cat] || 'bg-gray-500';
        },

        taskStatusBadge(status) {
            const map = { Open: 'bg-gray-100 text-gray-600', InProgress: 'bg-blue-100 text-blue-700',
                Completed: 'bg-green-100 text-green-700', Overdue: 'bg-red-100 text-red-700' };
            return map[status] || 'bg-gray-100 text-gray-600';
        },

        taskStatusDot(status) {
            const map = { Open: 'bg-gray-400', InProgress: 'bg-blue-500', Completed: 'bg-green-500', Overdue: 'bg-red-500' };
            return map[status] || 'bg-gray-400';
        }
    };
}
</script>
}
