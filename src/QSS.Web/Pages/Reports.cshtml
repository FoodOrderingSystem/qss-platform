@page
@model QSS.Web.Pages.ReportsModel
@{ ViewData["Title"] = "Reports & Analytics"; }

<div x-data="reportsApp()" x-init="load()">
    <div class="page-header">
        <div><h1 class="text-2xl font-bold text-gray-900">Reports & Analytics</h1>
        <p class="text-sm text-gray-500">Task completion, employee performance, and inventory reports</p></div>
        <button @@click="exportCsv()" class="btn-secondary flex-shrink-0"><i class="fas fa-download"></i> Export CSV</button>
    </div>

    <!-- Charts Row -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Task Status Chart -->
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
            <h2 class="font-semibold text-gray-800 mb-4">Task Status Distribution</h2>
            <canvas id="taskStatusChart" height="200"></canvas>
        </div>

        <!-- Employee Performance Chart -->
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
            <h2 class="font-semibold text-gray-800 mb-4">Employee Completion Rate</h2>
            <canvas id="employeeChart" height="200"></canvas>
        </div>
    </div>

    <!-- Performance Table -->
    <div class="table-wrapper mb-6">
        <div class="px-5 py-4 border-b border-gray-100">
            <h2 class="font-semibold text-gray-800">Employee Performance Details</h2>
        </div>
        <div class="table-scroll">
        <table class="w-full text-sm" style="min-width:480px">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">Employee</th>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">Total Assigned</th>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">Completed</th>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">Completion Rate</th>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">Performance</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <template x-for="emp in data.topPerformers ?? []" :key="emp.userId">
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 rounded-full bg-gradient-to-br from-blue-400 to-purple-500 flex items-center justify-center text-white text-xs font-bold"
                                     x-text="emp.userName?.charAt(0)"></div>
                                <span class="font-medium text-gray-900" x-text="emp.userName"></span>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-gray-600" x-text="emp.totalAssigned"></td>
                        <td class="px-4 py-3 text-gray-600" x-text="emp.totalCompleted"></td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2">
                                <div class="w-24 bg-gray-100 rounded-full h-1.5">
                                    <div class="h-1.5 rounded-full bg-blue-500" :style="`width:${emp.completionRate ?? 0}%`"></div>
                                </div>
                                <span class="text-sm" x-text="(emp.completionRate ?? 0) + '%'"></span>
                            </div>
                        </td>
                        <td class="px-4 py-3">
                            <span class="text-xs px-2 py-0.5 rounded-full font-medium"
                                  :class="emp.completionRate >= 80 ? 'bg-green-100 text-green-700' : emp.completionRate >= 50 ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700'"
                                  x-text="emp.completionRate >= 80 ? 'Excellent' : emp.completionRate >= 50 ? 'Good' : 'Needs Improvement'"></span>
                        </td>
                    </tr>
                </template>
            </tbody>
        </table>
        </div>
    </div>

    <!-- Inventory Summary -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="table-wrapper">
            <div class="px-5 py-4 border-b border-gray-100"><h2 class="font-semibold text-gray-800">Inventory Alerts</h2></div>
            <div class="p-5 space-y-3">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600">Low stock materials</span>
                    <span class="font-bold" :class="data.lowStockMaterials > 0 ? 'text-orange-600' : 'text-green-600'" x-text="data.lowStockMaterials ?? 0"></span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600">Expiring medications (30 days)</span>
                    <span class="font-bold" :class="data.expiringMedications > 0 ? 'text-red-600' : 'text-green-600'" x-text="data.expiringMedications ?? 0"></span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600">Overall QSS Score</span>
                    <span class="text-2xl font-bold text-blue-600" x-text="(data.qssScore ?? 0) + '%'"></span>
                </div>
            </div>
        </div>
        <div class="table-wrapper">
            <div class="px-5 py-4 border-b border-gray-100"><h2 class="font-semibold text-gray-800">Task Summary</h2></div>
            <div class="p-5 space-y-3">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600">Total Tasks</span>
                    <span class="font-bold text-gray-900" x-text="data.totalTasks ?? 0"></span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600">Completed</span>
                    <span class="font-bold text-green-600" x-text="data.completedTasks ?? 0"></span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600">In Progress</span>
                    <span class="font-bold text-yellow-600" x-text="data.inProgressTasks ?? 0"></span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600">Overdue</span>
                    <span class="font-bold text-red-600" x-text="data.overdueTasks ?? 0"></span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function reportsApp() {
    return {
        data: {},
        async load() {
            this.data = await apiRequest('GET', '/dashboard');
            this.$nextTick(() => {
                this.renderTaskChart();
                this.renderEmployeeChart();
            });
        },
        renderTaskChart() {
            const ctx = document.getElementById('taskStatusChart')?.getContext('2d');
            if (!ctx) return;
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Open', 'In Progress', 'Completed', 'Overdue'],
                    datasets: [{
                        data: [this.data.openTasks ?? 0, this.data.inProgressTasks ?? 0, this.data.completedTasks ?? 0, this.data.overdueTasks ?? 0],
                        backgroundColor: ['#3b82f6', '#f59e0b', '#10b981', '#ef4444'],
                        borderWidth: 0
                    }]
                },
                options: { plugins: { legend: { position: 'right' } }, cutout: '60%' }
            });
        },
        renderEmployeeChart() {
            const ctx = document.getElementById('employeeChart')?.getContext('2d');
            if (!ctx || !this.data.topPerformers?.length) return;
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: this.data.topPerformers.map(e => e.userName?.split(' ')[0] ?? ''),
                    datasets: [{
                        label: 'Completion Rate (%)',
                        data: this.data.topPerformers.map(e => e.completionRate),
                        backgroundColor: '#3b82f6',
                        borderRadius: 6
                    }]
                },
                options: {
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, max: 100 } }
                }
            });
        },
        async exportCsv() {
            const perf = this.data.topPerformers ?? [];
            const rows = [['Employee', 'Total Assigned', 'Completed', 'Completion Rate']];
            perf.forEach(e => rows.push([e.userName, e.totalAssigned, e.totalCompleted, e.completionRate + '%']));
            const csv = rows.map(r => r.join(',')).join('\n');
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url; a.download = 'qss-report.csv'; a.click();
            URL.revokeObjectURL(url);
        }
    };
}
</script>
}
