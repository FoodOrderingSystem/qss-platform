@page
@model QSS.Web.Pages.UsersModel
@{ ViewData["Title"] = "Users"; }

<div x-data="usersApp()" x-init="load()">
    <div class="flex items-center justify-between mb-6">
        <div><h1 class="text-2xl font-bold text-gray-900">User Management</h1>
        <p class="text-sm text-gray-500">Manage roles and access control</p></div>
        <button @@click="showCreate = true" class="btn-primary"><i class="fas fa-user-plus"></i> Add User</button>
    </div>

    <!-- Loading state -->
    <div x-show="loading" class="table-wrapper">
        <template x-for="i in [1,2,3,4]" :key="i">
            <div class="flex items-center gap-4 px-4 py-4 border-b border-gray-50 animate-pulse">
                <div class="w-8 h-8 bg-gray-100 rounded-full"></div>
                <div class="flex-1 h-4 bg-gray-100 rounded w-1/3"></div>
                <div class="w-36 h-4 bg-gray-100 rounded"></div>
                <div class="w-20 h-5 bg-gray-100 rounded-full"></div>
                <div class="w-16 h-5 bg-gray-100 rounded-full"></div>
            </div>
        </template>
    </div>

    <div x-show="!loading && users.length > 0" class="table-wrapper">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">User</th>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">Email</th>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">Role</th>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">Status</th>
                    <th class="px-4 py-3 text-left font-medium text-gray-500">Member Since</th>
                    <th class="px-4 py-3 text-right font-medium text-gray-500">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <template x-for="u in users" :key="u.id">
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-400 to-purple-500 flex items-center justify-center text-white text-xs font-bold"
                                     x-text="u.fullName?.charAt(0) ?? '?'"></div>
                                <span class="font-medium text-gray-900" x-text="u.fullName"></span>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-gray-600" x-text="u.email"></td>
                        <td class="px-4 py-3">
                            <span class="text-xs px-2 py-0.5 rounded-full font-medium" :class="roleColor(u.role)" x-text="u.role || 'No Role'"></span>
                        </td>
                        <td class="px-4 py-3">
                            <span class="text-xs px-2 py-0.5 rounded-full font-medium"
                                  :class="u.isActive ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'"
                                  x-text="u.isActive ? 'Active' : 'Inactive'"></span>
                        </td>
                        <td class="px-4 py-3 text-gray-500 text-xs" x-text="formatDate(u.createdAt)"></td>
                        <td class="px-4 py-3 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button @@click="openChangeRole(u)" class="text-xs text-blue-600 hover:underline">Change Role</button>
                                <button x-show="u.isActive" @@click="deactivate(u.id)" class="text-xs text-red-500 hover:underline">Deactivate</button>
                            </div>
                        </td>
                    </tr>
                </template>
            </tbody>
        </table>
    </div><!-- end users table -->

    <!-- Create User Modal -->
    <div x-show="showCreate" class="modal-backdrop" x-transition>
        <div class="modal p-6">
            <div class="flex items-center justify-between mb-5">
                <h2 class="text-lg font-bold text-gray-900">Add New User</h2>
                <button type="button" @@click="showCreate = false" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
            </div>
            <p class="text-xs text-gray-400 mb-4">Password must be at least 8 characters with upper, lower, digit, and special character.</p>
            <form x-on:submit.prevent="createUser()">
                <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-3">
                        <div><label class="form-label">First Name *</label>
                        <input x-model="form.firstName" type="text" class="form-input" required /></div>
                        <div><label class="form-label">Last Name *</label>
                        <input x-model="form.lastName" type="text" class="form-input" required /></div>
                    </div>
                    <div><label class="form-label">Email *</label>
                    <input x-model="form.email" type="email" class="form-input" required /></div>
                    <div><label class="form-label">Password *</label>
                    <input x-model="form.password" type="password" class="form-input" required /></div>
                    <div><label class="form-label">Role</label>
                    <select x-model="form.role" class="form-input">
                        <option value="Admin">Admin</option>
                        <option value="Dentist">Dentist</option>
                        <option value="DentalAssistant">Dental Assistant</option>
                        <option value="Trainee">Trainee</option>
                    </select></div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" @@click="showCreate = false" class="btn-secondary">Cancel</button>
                    <button type="submit" class="btn-primary">Create User</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Change Role Modal -->
    <div x-show="showRoleChange" class="modal-backdrop" x-transition>
        <div class="modal p-6" style="max-width:400px">
            <h2 class="text-lg font-bold text-gray-900 mb-1">Change Role</h2>
            <p class="text-sm text-gray-500 mb-5" x-text="selectedUser?.fullName"></p>
            <div><label class="form-label">New Role</label>
            <select x-model="newRole" class="form-input">
                <option value="Superadmin">Superadmin</option>
                <option value="Admin">Admin</option>
                <option value="Dentist">Dentist</option>
                <option value="DentalAssistant">Dental Assistant</option>
                <option value="Trainee">Trainee</option>
            </select></div>
            <div class="flex justify-end gap-3 mt-6">
                <button @@click="showRoleChange = false" class="btn-secondary">Cancel</button>
                <button @@click="changeRole()" class="btn-primary">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function usersApp() {
    return {
        users: [], showCreate: false, showRoleChange: false, selectedUser: null, newRole: '', loading: true,
        form: { firstName: '', lastName: '', email: '', password: '', role: 'DentalAssistant' },

        async load() {
            this.loading = true;
            try { this.users = await apiRequest('GET', '/users'); }
            catch(e) { showToast('Failed to load users', 'error'); }
            finally { this.loading = false; }
        },

        async createUser() {
            try {
                await apiRequest('POST', '/users', this.form);
                this.showCreate = false; await this.load(); showToast('User created successfully');
            } catch(e) { showToast('Failed to create user. Check password requirements.', 'error'); }
        },

        openChangeRole(user) { this.selectedUser = user; this.newRole = user.role || ''; this.showRoleChange = true; },

        async changeRole() {
            try {
                await apiRequest('PUT', `/users/${this.selectedUser.id}/role`, { role: this.newRole });
                this.showRoleChange = false; await this.load(); showToast('Role updated');
            } catch(e) { showToast('Failed', 'error'); }
        },

        async deactivate(id) {
            if(!confirm('Deactivate this user?')) return;
            try { await apiRequest('PUT', `/users/${id}/deactivate`, {}); await this.load(); showToast('User deactivated'); }
            catch(e) { showToast('Failed', 'error'); }
        },

        roleColor(role) {
            const map = { Superadmin: 'bg-purple-100 text-purple-700', Admin: 'bg-blue-100 text-blue-700',
                Dentist: 'bg-green-100 text-green-700', DentalAssistant: 'bg-orange-100 text-orange-700',
                Trainee: 'bg-gray-100 text-gray-700' };
            return map[role] || 'bg-gray-100 text-gray-600';
        }
    };
}
</script>
}
